{
  "name": "n8n-nodes-tangem",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Tangem NFC card wallet integration providing 26 resources and 200+ operations for multi-chain cryptocurrency signing, card management, and hardware wallet workflows. Includes support for Tangem Wallet 2.0/3, Tangem Note, and Tangem Ring.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-tangem.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-tangem#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-tangem/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "tangem",
    "nfc",
    "hardware-wallet",
    "crypto",
    "blockchain",
    "bitcoin",
    "ethereum",
    "solana",
    "cardano",
    "multi-chain",
    "wallet",
    "signing",
    "transaction",
    "cold-storage",
    "smart-card"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/TangemCard.credentials.js",
      "dist/credentials/TangemApp.credentials.js",
      "dist/credentials/TangemNetwork.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Tangem/Tangem.node.js",
      "dist/nodes/Tangem/TangemTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ethers": "^6.9.0",
    "bitcoinjs-lib": "^6.1.5",
    "@solana/web3.js": "^1.87.6",
    "bip32": "^4.0.0",
    "bip39": "^3.1.0",
    "bs58": "^5.0.0",
    "secp256k1": "^5.0.0",
    "elliptic": "^6.5.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/elliptic": "^6.4.18",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}